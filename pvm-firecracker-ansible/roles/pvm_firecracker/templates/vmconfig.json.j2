{
  "boot-source": {
    "kernel_image_path": "{{ pvm_dir }}/vmlinux-pvm",
    "boot_args": "console=ttyS0 reboot=k panic=1"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "{{ pvm_dir }}/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "network-interfaces": [
    {
      "iface_id": "net1",
      "guest_mac": "{{ vm_guest_mac }}",
      "host_dev_name": "{{ vm_tap_dev }}"
    }
  ],
  "machine-config": {
    "vcpu_count": {{ vm_vcpus }},
    "mem_size_mib": {{ vm_mem_mib }}
  }
}
