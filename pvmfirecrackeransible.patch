diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/20-firecracker.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/20-firecracker.yml
new file mode 100644
index 0000000..ef5eeca
--- /dev/null
+++ b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/20-firecracker.yml
@@ -0,0 +1,69 @@
+---
+# Build the PVM-aware Firecracker. The fork's `main` tracks upstream and the
+# PVM source changes are tiny + surgical, so we re-apply them here idempotently
+# instead of depending on them being committed.
+
+- name: Install rustup + toolchain (user-space, no root toolchain needed)
+  ansible.builtin.shell: |
+    set -e
+    curl -sSf --proto '=https' --tlsv1.2 https://sh.rustup.rs -o /tmp/rustup-init.sh
+    sh /tmp/rustup-init.sh -y --default-toolchain stable --profile minimal
+  args:
+    creates: "{{ ansible_env.HOME }}/.cargo/bin/cargo"
+
+- name: Clone the Firecracker fork
+  ansible.builtin.git:
+    repo: "{{ firecracker_repo }}"
+    dest: "{{ firecracker_src }}"
+    version: "{{ firecracker_version }}"
+    depth: 1
+    single_branch: true
+    force: false
+
+# ---- PVM forward-port: change #1 ----------------------------------------
+# Disable per-vCPU TSC scaling. PVM does not support KVM_CAP_TSC_CONTROL, so
+# the upstream call would fail and Firecracker would refuse to boot a guest.
+- name: "PVM patch: make set_tsc_khz() a no-op"
+  ansible.builtin.replace:
+    path: "{{ firecracker_src }}/src/vmm/src/arch/x86_64/vcpu.rs"
+    regexp: 'self\.fd\.set_tsc_khz\(tsc_freq\)\.map_err\(SetTscError\)'
+    replace: '{ let _ = tsc_freq; Ok(()) } // PVM: TSC scaling unsupported'
+
+# ---- PVM forward-port: change #2 ----------------------------------------
+# Relax the static-CPU-template model check so templates work across CPUs.
+# `return Err(InvalidCpuModel);` (note: no enum prefix) is unique to the live
+# code path; the test-only references use GetCpuTemplateError::InvalidCpuModel.
+- name: "PVM patch: relax static CPU-template model check"
+  ansible.builtin.replace:
+    path: "{{ firecracker_src }}/src/vmm/src/cpu_config/x86_64/custom_cpu_template.rs"
+    regexp: '^\s*return Err\(InvalidCpuModel\);'
+    replace: '                        { /* PVM: skip CPU-model compatibility check */ }'
+
+# A gnu-target build has no matching seccomp JSON, so Firecracker's build.rs
+# falls back to an empty filter automatically (no libseccomp at runtime).
+- name: Build Firecracker + jailer ({{ fc_target }}, release)
+  ansible.builtin.command:
+    cmd: cargo build --release --target {{ fc_target }} --package firecracker --package jailer
+    chdir: "{{ firecracker_src }}"
+    creates: "{{ firecracker_src }}/build/cargo_target/{{ fc_target }}/release/firecracker"
+  environment:
+    PATH: "{{ ansible_env.HOME }}/.cargo/bin:{{ ansible_env.PATH }}"
+    CARGO_TERM_PROGRESS_WHEN: "never"
+  async: 1800
+  poll: 20
+
+- name: Install firecracker + jailer binaries
+  ansible.builtin.copy:
+    src: "{{ firecracker_src }}/build/cargo_target/{{ fc_target }}/release/{{ item }}"
+    dest: "{{ pvm_dir }}/{{ item }}"
+    mode: "0755"
+    remote_src: true
+  loop:
+    - firecracker
+    - jailer
+
+- name: Symlink firecracker into PATH
+  ansible.builtin.file:
+    src: "{{ pvm_dir }}/firecracker"
+    dest: /usr/local/bin/firecracker
+    state: link
diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/30-host-kernel.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/30-host-kernel.yml
new file mode 100644
index 0000000..80155e6
--- /dev/null
+++ b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/30-host-kernel.yml
@@ -0,0 +1,71 @@
+---
+# Build + install the PVM host kernel. Based on the running distro kernel config
+# so all the cloud VM's drivers (virtio, ext4, ...) are retained, plus CONFIG_KVM_PVM.
+
+- name: Clone PVM host kernel source ({{ pvm_linux_branch }})
+  ansible.builtin.git:
+    repo: "{{ pvm_linux_repo }}"
+    dest: "{{ host_kernel_src }}"
+    version: "{{ pvm_linux_branch }}"
+    depth: 1
+    single_branch: true
+    force: false
+
+- name: Configure host kernel (running config + PVM + build fixes)
+  ansible.builtin.shell:
+    chdir: "{{ host_kernel_src }}"
+    cmd: |
+      set -euo pipefail
+      cp /boot/config-$(uname -r) .config
+      scripts/config --module   KVM_PVM
+      scripts/config --module   KVM
+      scripts/config --set-str  SYSTEM_TRUSTED_KEYS ""        # distro signing keys we don't have
+      scripts/config --set-str  SYSTEM_REVOCATION_KEYS ""
+      scripts/config --disable  MODULE_SIG_FORCE
+      scripts/config --disable  DEBUG_INFO_BTF                # speed/size; avoids pahole
+      scripts/config --disable  DEBUG_INFO_BTF_MODULES
+      scripts/config --disable  DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT
+      scripts/config --enable   DEBUG_INFO_NONE
+      scripts/config --set-str  LOCALVERSION "{{ host_localversion }}"
+      scripts/config --disable  LOCALVERSION_AUTO
+      scripts/config --disable  UAPI_HEADER_TEST              # PVM's pvm_para.h fails the standalone test
+      make olddefconfig
+  args:
+    creates: "{{ host_kernel_src }}/.config"
+
+- name: Build host kernel (long-running)
+  ansible.builtin.command:
+    cmd: make -j{{ make_jobs }}
+    chdir: "{{ host_kernel_src }}"
+    creates: "{{ host_kernel_src }}/arch/x86/boot/bzImage"
+  async: 5400
+  poll: 30
+
+- name: Read built kernel release string
+  ansible.builtin.slurp:
+    src: "{{ host_kernel_src }}/include/config/kernel.release"
+  register: _krelease
+
+- name: Set pvm_kernel_release fact (e.g. 6.12.33-pvm+)
+  ansible.builtin.set_fact:
+    pvm_kernel_release: "{{ (_krelease.content | b64decode) | trim }}"
+
+- name: Install modules + image (+ dracut initramfs + BLS entry)
+  ansible.builtin.shell:
+    chdir: "{{ host_kernel_src }}"
+    cmd: |
+      set -e
+      make -j{{ make_jobs }} modules_install
+      make install
+  args:
+    creates: "/boot/vmlinuz-{{ pvm_kernel_release }}"
+
+- name: Confirm kvm-pvm module was built and installed
+  ansible.builtin.stat:
+    path: "/lib/modules/{{ pvm_kernel_release }}/kernel/arch/x86/kvm/kvm-pvm.ko"
+  register: _kvmpvm_ko
+
+- name: Assert kvm-pvm.ko present
+  ansible.builtin.assert:
+    that: _kvmpvm_ko.stat.exists
+    fail_msg: "kvm-pvm.ko not found — CONFIG_KVM_PVM did not build."
diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/40-guest-kernel.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/40-guest-kernel.yml
new file mode 100644
index 0000000..de77b9e
--- /dev/null
+++ b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/40-guest-kernel.yml
@@ -0,0 +1,48 @@
+---
+# Build the PVM guest kernel (a single uncompressed vmlinux ELF that Firecracker
+# boots directly). Uses a SEPARATE clone so it doesn't clash with the in-tree
+# host-kernel build objects.
+
+- name: Clone PVM guest kernel source (separate tree)
+  ansible.builtin.git:
+    repo: "{{ pvm_linux_repo }}"
+    dest: "{{ guest_kernel_src }}"
+    version: "{{ pvm_linux_branch }}"
+    depth: 1
+    single_branch: true
+    force: false
+
+- name: Download the canonical PVM guest kernel config
+  ansible.builtin.get_url:
+    url: "{{ pvm_guest_config_url }}"
+    dest: "{{ build_root }}/pvm-guest.config"
+    mode: "0644"
+
+- name: "Configure guest kernel (FC-ready virtio/ext4/serial built-in, PVM_GUEST=y)"
+  ansible.builtin.shell:
+    chdir: "{{ guest_kernel_src }}"
+    cmd: |
+      set -euo pipefail
+      cp {{ build_root }}/pvm-guest.config .config
+      scripts/config --enable   PVM_GUEST
+      scripts/config --enable   KVM_GUEST
+      scripts/config --disable  UAPI_HEADER_TEST
+      scripts/config --set-str  SYSTEM_TRUSTED_KEYS ""
+      scripts/config --set-str  SYSTEM_REVOCATION_KEYS ""
+      scripts/config --set-str  LOCALVERSION "{{ guest_localversion }}"
+      make olddefconfig
+  args:
+    creates: "{{ guest_kernel_src }}/.config"
+
+- name: Build guest vmlinux (long-running)
+  ansible.builtin.command:
+    cmd: make -j{{ make_jobs }} vmlinux
+    chdir: "{{ guest_kernel_src }}"
+    creates: "{{ guest_kernel_src }}/vmlinux"
+  async: 3600
+  poll: 30
+
+- name: Strip + install guest vmlinux
+  ansible.builtin.command:
+    cmd: objcopy --strip-debug "{{ guest_kernel_src }}/vmlinux" "{{ pvm_dir }}/vmlinux-pvm"
+    creates: "{{ pvm_dir }}/vmlinux-pvm"
diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/50-rootfs.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/50-rootfs.yml
new file mode 100644
