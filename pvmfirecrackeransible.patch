--- /dev/null
+++ b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/50-rootfs.yml
@@ -0,0 +1,28 @@
+---
+# Build an ext4 rootfs for the microVM from the Firecracker CI Ubuntu image,
+# with an SSH key injected so the smoke test can log in.
+
+- name: Download Ubuntu rootfs (squashfs)
+  ansible.builtin.get_url:
+    url: "{{ rootfs_squashfs_url }}"
+    dest: "{{ build_root }}/rootfs.squashfs"
+    mode: "0644"
+
+- name: Generate guest SSH keypair
+  ansible.builtin.command:
+    cmd: ssh-keygen -t ed25519 -N "" -f "{{ pvm_dir }}/id_rsa"
+    creates: "{{ pvm_dir }}/id_rsa"
+
+- name: Build ext4 rootfs with the key injected
+  ansible.builtin.shell:
+    cmd: |
+      set -euo pipefail
+      rm -rf "{{ build_root }}/squashfs-root"
+      unsquashfs -q -d "{{ build_root }}/squashfs-root" "{{ build_root }}/rootfs.squashfs"
+      mkdir -p "{{ build_root }}/squashfs-root/root/.ssh"
+      cp "{{ pvm_dir }}/id_rsa.pub" "{{ build_root }}/squashfs-root/root/.ssh/authorized_keys"
+      chown -R root:root "{{ build_root }}/squashfs-root"
+      truncate -s {{ rootfs_size }} "{{ pvm_dir }}/rootfs.ext4"
+      mkfs.ext4 -q -F -d "{{ build_root }}/squashfs-root" "{{ pvm_dir }}/rootfs.ext4"
+  args:
+    creates: "{{ pvm_dir }}/rootfs.ext4"
diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/60-boot.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/60-boot.yml
new file mode 100644
index 0000000..21fd8de
--- /dev/null
+++ b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/60-boot.yml
@@ -0,0 +1,65 @@
+---
+# Configure GRUB + module loading and (optionally) reboot into the PVM kernel.
+
+- name: Read current PVM kernel boot args
+  ansible.builtin.command: "grubby --info=/boot/vmlinuz-{{ pvm_kernel_release }}"
+  register: _grubinfo
+  changed_when: false
+
+- name: Ensure pti=off on the PVM kernel (PVM is incompatible with page-table isolation)
+  ansible.builtin.command: "grubby --update-kernel=/boot/vmlinuz-{{ pvm_kernel_release }} --args=pti=off"
+  when: "'pti=off' not in _grubinfo.stdout"
+
+- name: Auto-load kvm-pvm at boot
+  ansible.builtin.copy:
+    dest: /etc/modules-load.d/kvm-pvm.conf
+    content: "kvm-pvm\n"
+    mode: "0644"
+
+- name: Blacklist vendor KVM modules (cannot coexist with kvm-pvm)
+  ansible.builtin.copy:
+    dest: /etc/modprobe.d/blacklist-kvm-vendor.conf
+    content: "blacklist kvm_amd\nblacklist kvm_intel\n"
+    mode: "0644"
+
+- name: Make the PVM kernel the default boot entry
+  ansible.builtin.command: "grubby --set-default=/boot/vmlinuz-{{ pvm_kernel_release }}"
+  when: pvm_set_default_kernel | bool
+  changed_when: true
+
+- name: Reboot into the PVM kernel
+  ansible.builtin.reboot:
+    reboot_timeout: 900
+    msg: "Rebooting into PVM kernel {{ pvm_kernel_release }}"
+  when: pvm_reboot | bool
+
+# ---- post-reboot verification ----
+- name: Confirm we are running the PVM kernel
+  ansible.builtin.command: uname -r
+  register: _unr
+  changed_when: false
+  when: pvm_reboot | bool
+
+- name: Assert running kernel == built PVM kernel
+  ansible.builtin.assert:
+    that: _unr.stdout == pvm_kernel_release
+    fail_msg: "Booted '{{ _unr.stdout }}', expected '{{ pvm_kernel_release }}'. Check GRUB default / console."
+  when: pvm_reboot | bool
+
+- name: Load kvm-pvm now
+  ansible.builtin.command: modprobe kvm-pvm
+  changed_when: false
+  when: pvm_reboot | bool
+
+- name: Check /dev/kvm (the PVM software interface)
+  ansible.builtin.stat:
+    path: /dev/kvm
+  register: _devkvm
+  when: pvm_reboot | bool
+
+- name: Assert /dev/kvm exists — PVM is active
+  ansible.builtin.assert:
+    that: _devkvm.stat.exists
+    success_msg: "PVM active: /dev/kvm present on {{ pvm_kernel_release }}."
+    fail_msg: "kvm-pvm did not create /dev/kvm. Check `dmesg | grep -i pvm` (FSGSBASE?)."
+  when: pvm_reboot | bool
diff --git a/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/70-smoke-test.yml b/pvm-firecracker-ansible/roles/pvm_firecracker/tasks/70-smoke-test.yml
